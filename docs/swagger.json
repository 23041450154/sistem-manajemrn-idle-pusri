{
    "swagger": "2.0",
    "info": {
        "description": "API documentation for Backend Idle (equipment/idle management system)",
        "title": "Backend Idle API",
        "contact": {},
        "version": "1.0"
    },
    "basePath": "/api",
    "paths": {
        "/approvals": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mengambil daftar approval request, dengan filter opsional status dan request_type",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "approvals"
                ],
                "summary": "List approval requests",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Filter status approval, contoh: PENDING",
                        "name": "status",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Filter tipe request, contoh: EQUIPMENT_REGISTRATION",
                        "name": "request_type",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/approvals/{id}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mengambil detail satu approval request beserta tahapan (steps)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "approvals"
                ],
                "summary": "Get approval detail",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Approval Request ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/approvals/{id}/review": {
            "patch": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Memproses keputusan Manajer Rendal terhadap approval request (APPROVE atau REVISION). Jika APPROVE, equipment terkait otomatis berubah menjadi IDLE.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "approvals"
                ],
                "summary": "Review approval request",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Approval Request ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Review decision",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/request.ReviewApprovalRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/attachments/upload": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mengunggah berkas lampiran (JPG, PNG, atau PDF, maks 5 MB) yang terkait dengan sebuah equipment",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Attachment"
                ],
                "summary": "Unggah berkas lampiran equipment",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID Equipment",
                        "name": "equipment_id",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Kategori lampiran",
                        "name": "category",
                        "in": "formData"
                    },
                    {
                        "type": "file",
                        "description": "Berkas yang diunggah (JPG/PNG/PDF, maks 5 MB)",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "File berkas berhasil diunggah",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "equipment_id tidak valid / aset tidak ditemukan / file wajib diunggah / ukuran melebihi batas",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "415": {
                        "description": "Format file tidak didukung",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Kesalahan server",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "description": "Login menggunakan NPP dan password, mengembalikan JWT token beserta data user",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Login user",
                "parameters": [
                    {
                        "description": "Login credentials",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/controllers.LoginInput"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "description": "Menghapus cookie token untuk logout",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Logout user",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/equipment": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mengambil daftar seluruh data equipment/aset idle",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Equipment"
                ],
                "summary": "Ambil semua equipment",
                "responses": {
                    "200": {
                        "description": "Data berhasil diambil",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Kesalahan server",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mendaftarkan aset/equipment idle baru dengan status awal REGISTERED",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Equipment"
                ],
                "summary": "Daftarkan equipment baru",
                "parameters": [
                    {
                        "description": "Data equipment baru",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/request.EquipmentRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Aset baru berhasil didaftarkan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Validasi gagal / kode alat sudah terdaftar",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Kesalahan server",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/equipment/{id}": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Mengambil detail satu equipment berdasarkan ID, termasuk relasi Condition, Status, StorageLocation, dan ObjectType",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Equipment"
                ],
                "summary": "Ambil detail equipment",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID Equipment",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Berhasil mengambil data equipment",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Aset tidak ditemukan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Menghapus data equipment berdasarkan ID",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Equipment"
                ],
                "summary": "Hapus equipment",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID Equipment",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Aset berhasil dihapus",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Aset tidak ditemukan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Kesalahan server",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            },
            "patch": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Memperbarui sebagian field equipment (partial update). Hanya untuk role RENDAL_PEMELIHARAAN. Jika equipment punya approval berstatus REVISION_REQUIRED, approval otomatis dikembalikan ke PENDING.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Equipment"
                ],
                "summary": "Perbarui data equipment",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID Equipment",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Field equipment yang ingin diubah",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/request.UpdateEquipmentRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Aset berhasil diperbarui",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Format request tidak valid / tidak ada data yang diubah",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "403": {
                        "description": "Role tidak diizinkan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Aset tidak ditemukan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Kesalahan server",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/equipment/{id}/validate": {
            "patch": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Menilai kelayakan (utilizable) sebuah equipment. Hanya untuk role INSPEKSI_TEKNIK. Jika tidak layak, status equipment menjadi REJECTED. Jika layak, status menjadi VALIDATED dan dibuatkan approval untuk Manajer Rendal.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Equipment"
                ],
                "summary": "Penilaian kelayakan equipment",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID Equipment",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Hasil penilaian kelayakan",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/request.ValidateEquipmentRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Penilaian kelayakan berhasil disimpan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "400": {
                        "description": "Format request tidak valid / field wajib tidak diisi",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "403": {
                        "description": "Role tidak diizinkan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "404": {
                        "description": "Aset tidak ditemukan",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Kesalahan server",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "controllers.LoginInput": {
            "type": "object",
            "required": [
                "npp",
                "password"
            ],
            "properties": {
                "npp": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        },
        "request.EquipmentRequest": {
            "type": "object",
            "required": [
                "equipment_code",
                "id_condition",
                "id_object_type",
                "name",
                "plant"
            ],
            "properties": {
                "book_value": {
                    "type": "number"
                },
                "equipment_code": {
                    "type": "string"
                },
                "func_loc": {
                    "type": "string"
                },
                "id_condition": {
                    "type": "integer"
                },
                "id_object_type": {
                    "type": "integer"
                },
                "id_storage_location": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "notes": {
                    "type": "string"
                },
                "original_value": {
                    "type": "number"
                },
                "plant": {
                    "type": "string"
                },
                "plant_description": {
                    "type": "string"
                },
                "vendor": {
                    "type": "string"
                },
                "year": {
                    "type": "integer"
                }
            }
        },
        "request.ReviewApprovalRequest": {
            "type": "object",
            "properties": {
                "action": {
                    "description": "Action: \"APPROVE\" atau \"REVISION\"",
                    "type": "string"
                },
                "notes": {
                    "type": "string"
                }
            }
        },
        "request.UpdateEquipmentRequest": {
            "type": "object",
            "properties": {
                "book_value": {
                    "type": "number"
                },
                "equipment_code": {
                    "type": "string"
                },
                "func_loc": {
                    "type": "string"
                },
                "id_condition": {
                    "type": "integer"
                },
                "id_object_type": {
                    "type": "integer"
                },
                "id_storage_location": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "notes": {
                    "type": "string"
                },
                "original_value": {
                    "type": "number"
                },
                "plant": {
                    "type": "string"
                },
                "plant_description": {
                    "type": "string"
                },
                "vendor": {
                    "type": "string"
                },
                "year": {
                    "type": "integer"
                }
            }
        },
        "request.ValidateEquipmentRequest": {
            "type": "object",
            "properties": {
                "is_utilizable": {
                    "type": "boolean"
                },
                "notes": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Ketik \"Bearer\" diikuti spasi dan token JWT. Contoh: \"Bearer eyJhbGciOi...\"",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}